# TourAPI collection
KOREA_TOUR_API_KEY=

# Shared MySQL database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=tour_recommender
MYSQL_CONNECT_TIMEOUT=10

# AIHub preprocessing and MySQL loading
AIHUB_DATA_DIRECTORY=data/processed/aihub
AIHUB_LOAD_BATCH_SIZE=5000

# OpenAI embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB (CHROMA_MODE: persistent or http)
CHROMA_MODE=persistent
CHROMA_PERSIST_DIRECTORY=data/vectorstore
CHROMA_COLLECTION=jeju_places
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_SSL=false
